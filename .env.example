NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Affiliate IDs for destination overview (optional).
# Leave blank to produce clean links with no affiliate tracking.
NEXT_PUBLIC_BOOKING_AFFILIATE_ID=
NEXT_PUBLIC_AIRBNB_AFFILIATE_ID=
NEXT_PUBLIC_RENTALCARS_AFFILIATE_ID=

# Stage 7 — Flight status cron
# Generate any random string; Vercel Cron must send it as Bearer token.
CRON_SECRET=generate-a-random-string-here
# Optional: real-time flight lookups via https://aviationstack.com (free tier available).
# If unset, the cron uses a placeholder that always reports "on_time".
AVIATIONSTACK_API_KEY=optional-for-real-time-status
# Optional: service-role key for cron (falls back to anon key if missing).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Daily WhatsApp broadcast (Stage 17) ───────────────────────────────
# Required for /api/cron/daily-whatsapp to actually deliver messages.
# Without these, the cron runs but every send fails silently.
#
# Provider: "baileys" (self-hosted bot) or "twilio" (paid cloud API).
WHATSAPP_PROVIDER=baileys
#
# Baileys: PUBLIC URL of your bot's send endpoint. localhost will NOT work
# from Vercel — expose the bot via ngrok / Cloudflare Tunnel / public host.
# Example: https://your-bot.ngrok.app/api/send
WHATSAPP_BOT_URL=
#
# Twilio (only if WHATSAPP_PROVIDER=twilio):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
